{
  "build": {
    "beforeBuildCommand": "node tools/set-build-locale.mjs zh-CN && pnpm build"
  },
  "productName": "xiaolongxia",
  "mainBinaryName": "openclaw_launcher",
  "app": {
    "windows": [
      {
        "title": "xiaolongxia"
      }
    ]
  },
  "bundle": {
    "fileAssociations": [
      {
        "ext": [
          "claw"
        ],
        "name": "xiaolongxia package",
        "description": "xiaolongxia launcher package",
        "role": "Editor"
      }
    ],
    "windows": {
      "nsis": {
        "template": "windows/tauri-installer-template.nsi",
        "languages": [
          "SimpChinese"
        ],
        "customLanguageFiles": {
          "SimpChinese": "windows/SimpChinese.nsh"
        },
        "displayLanguageSelector": false
      }
    }
  }
}
