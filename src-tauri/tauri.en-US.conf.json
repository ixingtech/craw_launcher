{
  "build": {
    "beforeBuildCommand": "node tools/set-build-locale.mjs en-US && pnpm build"
  },
  "productName": "Craw Launcher",
  "mainBinaryName": "openclaw_launcher",
  "app": {
    "windows": [
      {
        "title": "Craw Launcher"
      }
    ]
  },
  "bundle": {
    "fileAssociations": [
      {
        "ext": [
          "claw"
        ],
        "name": "Craw Package",
        "description": "Craw Launcher package",
        "role": "Editor"
      }
    ],
    "windows": {
      "nsis": {
        "languages": [
          "English"
        ],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/yipuwangc/claws_launcher/releases/latest/download/latest-en-US.json"
      ],
      "pubkey": "untrusted comment: minisign public key: ED32FA91C0DF77CB\nRWTLd9/Akfoy7XWZVcf46tN1QdKvGjG3j55MFmseEuu6xlubv92cQwSs"
    }
  }
}
