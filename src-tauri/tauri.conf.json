{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "小龙虾启动器",
  "mainBinaryName": "小龙虾启动器",
  "version": "0.1.3",
  "identifier": "com.yipuwangc.openclawlauncher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "node tools/set-build-locale.mjs zh-CN && pnpm dev",
    "beforeBuildCommand": "node tools/set-build-locale.mjs zh-CN && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "小龙虾启动器",
        "width": 1220,
        "height": 780,
        "minWidth": 1040,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "fileAssociations": [
      {
        "ext": [
          "claw"
        ],
        "name": "小龙虾包",
        "description": "小龙虾启动器安装包",
        "role": "Editor"
      }
    ],
    "resources": [
      "resources/acp_stream_helper.mjs",
      "resources/gateway_subscriber.mjs"
    ],
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installerHooks": "windows/file-associations.nsh",
        "languages": [
          "SimpChinese",
          "English"
        ],
        "customLanguageFiles": {
          "SimpChinese": "windows/SimpChinese.nsh"
        },
        "displayLanguageSelector": true
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/yipuwangc/claws_launcher/releases/latest/download/latest-zh-CN.json"
      ],
      "pubkey": ""
    }
  }
}
