{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "зҒҸеҝӣз·ій“Ҹжғ§жғҺйҚ”г„Ҙж«’",
  "mainBinaryName": "openclaw_launcher",
  "version": "0.1.9",
  "identifier": "com.yipuwangc.openclawlauncher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "node tools/set-build-locale.mjs zh-CN && pnpm dev",
    "beforeBuildCommand": "node tools/set-build-locale.mjs zh-CN && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "зҒҸеҝӣз·ій“Ҹжғ§жғҺйҚ”г„Ҙж«’",
        "width": 1220,
        "height": 780,
        "minWidth": 1040,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "fileAssociations": [
      {
        "ext": [
          "claw"
        ],
        "name": "зҒҸеҝӣз·ій“Ҹжғ§еҜҳ",
        "description": "зҒҸеҝӣз·ій“Ҹжғ§жғҺйҚ”г„Ҙж«’зҖ№еӨҺо—ҠйҚ–?,",
        "role": "Editor"
      }
    ],
    "resources": [
      "resources/acp_stream_helper.mjs",
      "resources/gateway_subscriber.mjs"
    ],
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "template": "windows/tauri-installer-template.nsi",
        "installerIcon": "icons/icon.ico",
        "installerHooks": "windows/file-associations.nsh",
        "languages": [
          "SimpChinese",
          "English"
        ],
        "customLanguageFiles": {
          "SimpChinese": "windows/SimpChinese.nsh"
        },
        "displayLanguageSelector": true
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/yipuwangc/claws-launcher-releases/releases/latest/download/latest-zh-CN.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVEMzJGQTkxQzBERjc3Q0IKUldUTGQ5L0FrZm95N1hXWlZjZjQ2dE4xUWRLdkdqRzNqNTVNRm1zZUV1dTZ4bHVidjkyY1F3U3MK"
    }
  }
}
