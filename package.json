{
  "name": "openclaw-launcher",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:mac": "tauri build --bundles app,dmg",
    "build:mac-app": "tauri build --bundles app",
    "build:mac-dmg": "tauri build --bundles dmg",
    "build:mac:zh-CN": "tauri build --bundles app,dmg --config src-tauri/tauri.zh-CN.conf.json",
    "build:mac-app:zh-CN": "tauri build --bundles app --config src-tauri/tauri.zh-CN.conf.json",
    "build:mac-dmg:zh-CN": "tauri build --bundles dmg --config src-tauri/tauri.zh-CN.conf.json",
    "build:mac:en-US": "tauri build --bundles app,dmg --config src-tauri/tauri.en-US.conf.json",
    "build:mac-app:en-US": "tauri build --bundles app --config src-tauri/tauri.en-US.conf.json",
    "build:mac-dmg:en-US": "tauri build --bundles dmg --config src-tauri/tauri.en-US.conf.json",
    "build:nsis": "pnpm build:nsis:zh-CN && pnpm build:nsis:en-US",
    "build:nsis:zh-CN": "tauri build --bundles nsis --no-sign --config src-tauri/tauri.zh-CN.conf.json && node tools/rename-nsis-artifact.mjs zh-CN",
    "build:nsis:en-US": "tauri build --bundles nsis --no-sign --config src-tauri/tauri.en-US.conf.json && node tools/rename-nsis-artifact.mjs en-US",
    "build:nsis:ci": "pnpm build:nsis:ci:zh-CN && pnpm build:nsis:ci:en-US",
    "build:nsis:ci:zh-CN": "tauri build --bundles nsis --config src-tauri/tauri.zh-CN.conf.json && node tools/rename-nsis-artifact.mjs zh-CN",
    "build:nsis:ci:en-US": "tauri build --bundles nsis --config src-tauri/tauri.en-US.conf.json && node tools/rename-nsis-artifact.mjs en-US",
    "build:cli": "cargo build --manifest-path src-tauri/Cargo.toml --bin claws-cli --release",
    "build:cli:archive": "pnpm build:cli && node tools/package-cli.mjs",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.66.11",
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/plugin-process": "^2.2.1",
    "@tauri-apps/plugin-updater": "^2.7.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.2.5",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.5"
  }
}
